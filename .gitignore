# Never track heavy files
*.pkl
*.pickle

# Ignore future generated timestamped artifacts
*.pt
*.json

# Ignore regenerated local figures
tiny_graphs_notebooks/**/saved_artifacts/figures/

# Usual ignores
*.pth
*.ckpt
__pycache__/
*.pyc
.codex
.vscode/
.ipynb_checkpoints/
wandb/
experiment_logs/
tiny_graphs_notebooks/*/experiment_logs/
evolving_graphs/